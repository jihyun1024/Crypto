{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "C/C++ Compile Run: Compile",
            "type": "shell",
            "command": "${workspaceFolder}/../../../TDM-GCC/bin/gcc.exe",
            "args": [
                "-Wall",
                "-Wextra",
                "-g3",
                "${workspaceFolder}/Elliptic_Curve_Crypto/for_test.c",
                "${workspaceFolder}/Elliptic_Curve_Crypto/core/sha256.c",
                "${workspaceFolder}/Elliptic_Curve_Crypto/core/big_int.c",
                "${workspaceFolder}/Elliptic_Curve_Crypto/core/secp256k1_params.c",
                "${workspaceFolder}/Elliptic_Curve_Crypto/cryptography/csprng.c",
                "${workspaceFolder}/Elliptic_Curve_Crypto/cryptography/ecc_point.c",
                "-o",
                "${workspaceFolder}/Elliptic_Curve_Crypto/output/for_test.exe"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always"
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "C/C++ Compile Run: Compile with big_int (cng_rng)",
            "type": "shell",
            "command": "${workspaceFolder}/../../../TDM-GCC/bin/gcc.exe",
            "args": [
                "-Wall",
                "-Wextra",
                "-g3",
                "${fileDirname}\\cng_rng.c",
                "${fileDirname}\\big_int.c",
                "-lbcrypt",
                "-o",
                "${fileDirname}\\output\\cng_rng.exe"
            ],
            "group": "build",
            "presentation": {
                "reveal": "always"
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "C/C++ Compile Run: for_test (with Makefile)",
            "type": "shell",
            "command": "make",
            "args": [
                "-C",
                "${workspaceFolder}/Elliptic_Curve_Crypto"
            ],
            "group": "build",
            "presentation": {
                "reveal": "always"
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "C/C++ Run: for_test",
            "type": "shell",
            "command": "${workspaceFolder}/Elliptic_Curve_Crypto/output/for_test.exe",
            "group": {
                "kind": "test",
                "isDefault": false
            },
            "presentation": {
                "reveal": "always"
            },
            "dependsOn": [
                "C/C++ Compile Run: for_test (with Makefile)"
            ]
        }
    ]
}
